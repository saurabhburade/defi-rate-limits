{
  "name": "defi-rate-limits",
  "version": "0.0.1",
  "private": true,
  "workspaces": {
    "packages": [
      "packages/foundry",
      "packages/nextjs"
    ]
  },
  "scripts": {
    "account": "yarn workspace @defi-rate-limits/foundry account",
    "account:import": "yarn workspace @defi-rate-limits/foundry account:import",
    "account:generate": "yarn workspace @defi-rate-limits/foundry account:generate",
    "account:reveal-pk": "yarn workspace @defi-rate-limits/foundry account:reveal-pk",
    "chain": "yarn workspace @defi-rate-limits/foundry chain",
    "compile": "yarn workspace @defi-rate-limits/foundry compile",
    "deploy": "yarn workspace @defi-rate-limits/foundry deploy",
    "fork": "yarn workspace @defi-rate-limits/foundry fork",
    "format": "yarn workspace @defi-rate-limits/nextjs format && yarn workspace @defi-rate-limits/foundry format",
    "generate": "yarn workspace @defi-rate-limits/foundry account:generate",
    "lint": "yarn workspace @defi-rate-limits/nextjs lint && yarn workspace @defi-rate-limits/foundry lint",
    "next:build": "yarn workspace @defi-rate-limits/nextjs build",
    "next:check-types": "yarn workspace @defi-rate-limits/nextjs check-types",
    "postinstall": "husky",
    "precommit": "lint-staged",
    "start": "yarn workspace @defi-rate-limits/nextjs dev",
    "test": "yarn workspace @defi-rate-limits/foundry test",
    "verify": "yarn workspace @defi-rate-limits/foundry verify"
  },
  "resolutions": {
    "fast-xml-parser": "4.5.4",
    "form-data": "4.0.6",
    "protobufjs": "7.5.5",
    "sha.js": "2.4.12"
  },
  "packageManager": "yarn@3.2.3",
  "devDependencies": {
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10"
  },
  "engines": {
    "node": ">=20.18.3"
  }
}
